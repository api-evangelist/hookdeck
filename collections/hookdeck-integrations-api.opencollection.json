{
  "opencollection": "1.0.0",
  "info": {
    "name": "Hookdeck Integrations API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Integrations",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get integrations",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.hookdeck.com/2025-07-01/integrations",
            "params": [
              {
                "name": "label",
                "value": "",
                "type": "query"
              },
              {
                "name": "provider",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Get integrations"
        },
        {
          "info": {
            "name": "Create an integration",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.hookdeck.com/2025-07-01/integrations",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create an integration"
        },
        {
          "info": {
            "name": "Get an integration",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.hookdeck.com/2025-07-01/integrations/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get an integration"
        },
        {
          "info": {
            "name": "Update an integration",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.hookdeck.com/2025-07-01/integrations/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Update an integration"
        },
        {
          "info": {
            "name": "Delete an integration",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.hookdeck.com/2025-07-01/integrations/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Delete an integration"
        },
        {
          "info": {
            "name": "Attach an integration to a source",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.hookdeck.com/2025-07-01/integrations/:id/attach/:source_id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              },
              {
                "name": "source_id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Attach an integration to a source"
        },
        {
          "info": {
            "name": "Detach an integration from a source",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.hookdeck.com/2025-07-01/integrations/:id/detach/:source_id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              },
              {
                "name": "source_id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Detach an integration from a source"
        }
      ]
    }
  ],
  "bundled": true
}