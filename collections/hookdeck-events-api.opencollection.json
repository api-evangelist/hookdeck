              }
            ]
          },
          "docs": "This endpoint lists events, or a subset of events."
        },
        {
          "info": {
            "name": "Retrieve an event",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.hookdeck.com/2025-07-01/events/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "This endpoint retrieves a specific event. The response contains the `data` object with the properties `body` and `headers`, representing the original data for that request."
        },
        {
          "info": {
            "name": "Get a event raw body data",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.hookdeck.com/2025-07-01/events/:id/raw_body",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get a event raw body data"
        },
        {
          "info": {
            "name": "Retry an event",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.hookdeck.com/2025-07-01/events/:id/retry",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "This endpoint retries a specific event. Retrying an event will cause a new attempt to be made to deliver it to the destination."
        },
        {
          "info": {
            "name": "Cancel an event",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.hookdeck.com/2025-07-01/events/:id/cancel",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "This endpoint cancels a pending event. Only events with a status of `QUEUED`, `SCHEDULED`, or `HOLD` can be cancelled."
        },
        {
          "info": {
            "name": "Cancel an event",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.hookdeck.com/2025-07-01/events/:id/mute",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "This endpoint cancels a pending event. Only events with a status of `QUEUED`, `SCHEDULED`, or `HOLD` can be cancelled."
        }
      ]
    }
  ],
  "bundled": true
}