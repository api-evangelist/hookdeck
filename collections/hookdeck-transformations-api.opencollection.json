        },
        {
          "info": {
            "name": "Update a transformation",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.hookdeck.com/2025-07-01/transformations/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "This endpoint updates a transformation."
        },
        {
          "info": {
            "name": "Delete a transformation",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.hookdeck.com/2025-07-01/transformations/:id",
