        },
        {
          "info": {
            "name": "Create a transformation",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.hookdeck.com/2025-07-01/transformations",
            "body": {
              "type": "json",
              "data": "{}"
