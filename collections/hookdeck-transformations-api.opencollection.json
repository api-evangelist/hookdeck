        {
          "info": {
            "name": "Test a transformation",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.hookdeck.com/2025-07-01/transformations/run",
            "body": {
              "type": "json",
              "data": "{}"
            }
